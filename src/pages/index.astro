---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Cohetería Beauchef"
  description="Desarrollamos e investigamos tecnología para cohetería e ingeniería aeroespacial"
>
  <main class="flex flex-col bg-white">
    {/* Hero Section */}
    <section class="relative w-full h-[900px] bg-[#0A0A0A] overflow-hidden">
      {/* Background Image */}
      <img
        src="/main_image.JPG"
        alt="Hero Background"
        class="absolute inset-0 w-full h-full object-cover opacity-85"
      />
      
      {/* Hero Overlay */}
      <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A] via-[#1024b0e6] to-[#1025B9E6] opacity-45"></div>

      {/* Navbar */}
      <nav class="absolute top-0 w-full h-20 px-16 flex justify-between items-center z-10">
        <div class="flex items-center gap-3">
          <img src="/logo_borderless_adjusted.png" alt="Logo" class="w-11 h-11 object-fill" />
          <span class="text-white font-bold text-xl tracking-[2px]">COHETERÍA BEAUCHEF</span>
        </div>
        <div class="flex items-center gap-10">
          <a href="#" class="text-white font-semibold text-base hover:text-gray-300 transition-colors">Nosotros</a>
          <a href="#" class="text-white font-semibold text-base hover:text-gray-300 transition-colors">Proyectos</a>
          <a href="/equipo" class="text-white font-semibold text-base hover:text-gray-300 transition-colors">Equipo</a>
          <a href="#" class="text-white font-semibold text-base hover:text-gray-300 transition-colors">Sponsors</a>
          <a href="#" class="text-white font-semibold text-base hover:text-gray-300 transition-colors">Contacto</a>
        </div>
      </nav>

      {/* Hero Content */}
      <div class="absolute inset-0 flex flex-col justify-center items-center gap-6 px-16 z-10 text-center">
        <h1 class="text-white font-bold text-[100px] leading-none tracking-[-4px]">
          Cohetería Beauchef
        </h1>
        <p class="text-[#FFFFFFEE] font-normal text-2xl leading-relaxed tracking-[-0.5px]">
          Desarrollamos e investigamos tecnología<br />
          para cohetería e ingeniería aeroespacial
        </p>
        <div class="flex items-center gap-4 mt-4">
          <a href="#" class="flex items-center gap-2.5 px-12 py-6 bg-white shadow-[0_8px_20px_#FFFFFF40] rounded-sm hover:bg-gray-50 transition-colors">
            <span class="text-[#1025B9] font-bold text-lg">Ver Nuestros Proyectos</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1025B9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/equipo" class="flex items-center px-12 py-6 bg-white/10 border border-white/40 rounded-sm hover:bg-white/20 transition-colors">
            <span class="text-white font-semibold text-lg">Únete al Equipo</span>
          </a>
        </div>
      </div>
    </section>

    {/* About Section */}
    <section class="relative w-full h-[700px] bg-white overflow-hidden flex flex-col items-center pt-[100px]">
      {/* Grid Pattern Background */}
      <div class="absolute inset-0 opacity-[0.04] pointer-events-none">
        <div class="absolute left-[200px] top-0 w-px h-[800px] bg-[#2E34E0]"></div>
        <div class="absolute left-[400px] top-0 w-px h-[800px] bg-[#2E34E0]"></div>
        <div class="absolute left-[600px] top-0 w-px h-[800px] bg-[#2E34E0]"></div>
        <div class="absolute left-[800px] top-0 w-px h-[800px] bg-[#2E34E0]"></div>
        <div class="absolute left-[1000px] top-0 w-px h-[800px] bg-[#2E34E0]"></div>
        <div class="absolute left-[1200px] top-0 w-px h-[800px] bg-[#2E34E0]"></div>
        <div class="absolute left-0 top-[150px] w-full h-px bg-[#2E34E0]"></div>
        <div class="absolute left-0 top-[350px] w-full h-px bg-[#2E34E0]"></div>
        <div class="absolute left-0 top-[550px] w-full h-px bg-[#2E34E0]"></div>
      </div>

      <div class="w-full max-w-[900px] flex flex-col items-center gap-4 z-10 px-4">
        <h2 class="text-[#1C1C1E] font-bold text-6xl leading-[1.15] tracking-[-2px] text-center">
          Impulsando la ingeniería<br />aeroespacial desde Chile
        </h2>
        <p class="text-[#48484A] font-normal text-xl leading-relaxed text-center w-full max-w-[847px]">
          Formados por estudiantes de la Facultad de Ciencias Físicas y Matemáticas de la Universidad de Chile, desarrollamos e investigamos tecnología para cohetería e ingeniería aeroespacial. En 2025 logramos diseñar, fabricar y validar el primer motor cohete 100% desarrollado por estudiantes.
        </p>
      </div>

      <div class="absolute top-[450px] w-full max-w-[1200px] flex justify-center items-center gap-10 lg:gap-[120px] z-10 px-4">
        <div class="flex flex-col items-center gap-2">
          <span class="text-[#2E34E0] font-bold text-4xl lg:text-6xl">2023</span>
          <span class="text-[#8E8E93] font-normal text-sm lg:text-base text-center">Año de fundación</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-[#2E34E0] font-bold text-4xl lg:text-6xl">1052N</span>
          <span class="text-[#8E8E93] font-normal text-sm lg:text-base text-center">Empuje máximo alcanzado</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-[#2E34E0] font-bold text-4xl lg:text-6xl">20+</span>
          <span class="text-[#8E8E93] font-normal text-sm lg:text-base text-center">Estudiantes activos</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-[#2E34E0] font-bold text-4xl lg:text-6xl">100%</span>
          <span class="text-[#8E8E93] font-normal text-sm lg:text-base text-center">Motor de estudiantes</span>
        </div>
      </div>
    </section>

    {/* CTA Section */}
    <section class="w-full bg-[#1025B9] py-[140px] px-8 lg:px-[120px] flex flex-col items-center gap-8">
      <div class="w-full max-w-[800px] flex flex-col items-center gap-6">
        <h2 class="text-white font-bold text-4xl lg:text-6xl leading-[1.15] tracking-[-2px] text-center">
          ¿Quieres ser parte del equipo?
        </h2>
        <p class="text-white/80 font-normal text-lg leading-relaxed text-center w-full">
          Buscamos estudiantes de la FCFM con ganas de aplicar sus conocimientos en proyectos reales de ciencia espacial. No importa tu carrera: mecánica, eléctrica, química, computación... <br />¡te queremos en el equipo!
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
          <a href="#" class="flex items-center gap-2.5 px-12 py-6 bg-white shadow-[0_8px_20px_#FFFFFF40] rounded-sm hover:bg-gray-50 transition-colors">
            <span class="text-[#1025B9] font-bold text-lg">Postula Ahora</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1025B9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/equipo" class="flex items-center px-12 py-6 bg-white/10 border border-white/40 rounded-sm hover:bg-white/20 transition-colors">
            <span class="text-white font-semibold text-lg">Conoce al Equipo</span>
          </a>
        </div>
      </div>
    </section>

    {/* Instagram Section */}
    <section class="w-full bg-[#F8F9FA] py-[100px] px-8 lg:px-[120px] flex flex-col items-center gap-12">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E1306C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16.11 7.61h.01"/><path d="M12 15.61a3.61 3.61 0 1 0 0-7.22 3.61 3.61 0 0 0 0 7.22Z"/></svg>
        <a href="#" class="text-[#2E34E0] font-semibold text-lg hover:underline">@coheteriabeauchef</a>
      </div>

      <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {/* Card 1 */}
        <div class="w-full bg-white border border-[#E5E7EB] rounded-sm overflow-hidden flex flex-col">
          <div class="p-5 flex flex-col gap-3 h-[160px]">
            <p class="text-[#48484A] font-normal text-sm leading-relaxed line-clamp-4">
              🚀 ¡Nuevo aliado en el equipo!<br />
              Le damos la bienvenida a @maquintelrobotics quienes se suman como auspiciadores oficiales para este 2026. 🌌 Con su apoyo, nuestro proyecto está cada vez más cerca de despegar.
            </p>
            <div class="flex items-center gap-4 mt-auto">
              <span class="text-[#111118] font-normal text-sm">♡ 22</span>
              <span class="text-[#111118] font-normal text-sm">💬 0</span>
            </div>
          </div>
          <img src="/post_instagram_1.jpg" alt="Instagram Post 1" class="w-full h-[320px] object-cover" />
        </div>

        {/* Card 2 */}
        <div class="w-full bg-white border border-[#E5E7EB] rounded-sm overflow-hidden flex flex-col">
          <div class="p-5 flex flex-col gap-3 h-[160px]">
            <p class="text-[#48484A] font-normal text-sm leading-relaxed line-clamp-4">
              🚀¡Arrancamos fuerte el año!<br />
              Hoy damos la bienvenida a @alutipo.chile que se une como auspiciador de Cohetería Beauchef 🌠
            </p>
            <div class="flex items-center gap-4 mt-auto">
              <span class="text-[#111118] font-normal text-sm">♡ 31</span>
              <span class="text-[#111118] font-normal text-sm">💬 2</span>
            </div>
          </div>
          <img src="/post_instagram_2.jpg" alt="Instagram Post 2" class="w-full h-[320px] object-cover" />
        </div>

        {/* Card 3 */}
        <div class="w-full bg-white border border-[#E5E7EB] rounded-sm overflow-hidden flex flex-col">
          <div class="p-5 flex flex-col gap-3 h-[160px]">
            <p class="text-[#48484A] font-normal text-sm leading-relaxed line-clamp-4">
              🚀 ¡Seguimos creciendo!<br />
              Hoy damos la bienvenida a @fablabudechile que se une como colaborador de Cohetería Beauchef
            </p>
            <div class="flex items-center gap-4 mt-auto">
              <span class="text-[#111118] font-normal text-sm">♡ 27</span>
              <span class="text-[#111118] font-normal text-sm">💬 0</span>
            </div>
          </div>
          <img src="/post_instagram_3.jpg" alt="Instagram Post 3" class="w-full h-[320px] object-cover" />
        </div>
      </div>
    </section>

    {/* Sponsors Section */}
    <section class="w-full bg-white pt-[120px] pb-[120px] flex flex-col items-center gap-16 overflow-hidden">
      <div class="w-full flex flex-col items-center gap-6 px-8 lg:px-[120px]">
        <h2 class="text-[#111118] font-bold text-4xl lg:text-6xl leading-[1.15] tracking-[-2px] text-center">
          Auspiciadores
        </h2>
        <p class="text-[#48484A] font-normal text-xl text-center w-full max-w-[600px]">
          En Cohetería Beauchef agradecemos el apoyo de nuestros auspiciadores.
        </p>
      </div>

      <div class="relative w-full h-[120px] overflow-hidden max-w-[1440px] mx-auto">
        <div class="flex items-center h-full gap-20 px-10 animate-marquee whitespace-nowrap w-max">
          <img src="/auspiciadores/fcfm_logo.png" alt="FCFM" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/departamento_mecanica_logo.webp" alt="Mecánica" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/departamento_electrica_logo.png" alt="Eléctrica" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/fablab_logo.png" alt="FabLab" class="h-[75px] w-auto object-contain shrink-0" />
          <img src="/auspiciadores/maquintel_logo.png" alt="Maquintel" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/alutipo_logo.png" alt="Alutipo" class="h-20 w-auto object-contain shrink-0" />
          
          <img src="/auspiciadores/fcfm_logo.png" alt="FCFM" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/departamento_mecanica_logo.webp" alt="Mecánica" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/departamento_electrica_logo.png" alt="Eléctrica" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/fablab_logo.png" alt="FabLab" class="h-[75px] w-auto object-contain shrink-0" />
          <img src="/auspiciadores/maquintel_logo.png" alt="Maquintel" class="h-20 w-auto object-contain shrink-0" />
          <img src="/auspiciadores/alutipo_logo.png" alt="Alutipo" class="h-20 w-auto object-contain shrink-0" />
        </div>
        
        {/* Left Fade */}
        <div class="absolute left-0 top-0 w-[100px] lg:w-[200px] h-full bg-gradient-to-r from-white to-transparent pointer-events-none"></div>
        {/* Right Fade */}
        <div class="absolute right-0 top-0 w-[100px] lg:w-[200px] h-full bg-gradient-to-l from-white to-transparent pointer-events-none"></div>
      </div>
    </section>

    {/* Socials Banner */}
    <section class="w-full h-[120px] flex flex-col md:flex-row">
      <a href="#" class="flex-1 h-full bg-[#eb1bcd] flex justify-center items-center gap-4 hover:brightness-110 transition-all py-4 md:py-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16.11 7.61h.01"/><path d="M12 15.61a3.61 3.61 0 1 0 0-7.22 3.61 3.61 0 0 0 0 7.22Z"/></svg>
        <span class="text-white font-bold text-lg tracking-[2px]">INSTAGRAM</span>
      </a>
      <a href="#" class="flex-1 h-full bg-[#E81A1A] flex justify-center items-center gap-4 hover:brightness-110 transition-all py-4 md:py-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 7.1c.1-1.4 1.2-2.6 2.7-2.7C8.6 4 12 4 15.4 4c1.5 0 2.6 1.1 2.7 2.5.1 1.5.1 3.5.1 5.5s0 4-.1 5.5c-.1 1.4-1.2 2.6-2.7 2.7-3.4.4-6.8.4-10.2.4-1.5 0-2.6-1.1-2.7-2.5C2.4 16.1 2.4 14.1 2.4 12c0-2 .1-4 .1-4.9z"/><path d="m10 15 5-3-5-3v6z"/></svg>
        <span class="text-white font-bold text-lg tracking-[2px]">YOUTUBE</span>
      </a>
      <a href="#" class="flex-1 h-full bg-[#1D79B3] flex justify-center items-center gap-4 hover:brightness-110 transition-all py-4 md:py-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        <span class="text-white font-bold text-lg tracking-[2px]">LINKEDIN</span>
      </a>
      <a href="#" class="flex-1 h-full bg-[#000000] flex justify-center items-center gap-4 hover:brightness-110 transition-all py-4 md:py-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><path d="m9 9 12-2"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        <span class="text-white font-bold text-lg tracking-[2px]">TIKTOK</span>
      </a>
    </section>

    {/* Footer */}
    <footer class="w-full bg-[#0A0A0A] py-[100px] px-8 lg:px-[120px] flex flex-col gap-12">
      <div class="w-full flex flex-col lg:flex-row justify-between gap-12">
        <div class="w-full lg:w-[350px] flex flex-col gap-5">
          <div class="flex items-center gap-3">
            <img src="/logo_borderless_adjusted.png" alt="Logo" class="w-10 h-10 object-fill" />
            <span class="text-white font-bold text-lg tracking-[2px]">COHETERÍA BEAUCHEF</span>
          </div>
          <p class="text-white/60 font-normal text-base leading-relaxed">
            Impulsando el desarrollo de la ingeniería aeroespacial en Chile a través del talento estudiantil.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-12 sm:gap-[120px]">
          <div class="flex flex-col gap-6">
            <h3 class="text-white font-semibold text-lg">Navegación</h3>
            <div class="flex flex-col gap-4">
              <a href="#" class="text-white/60 hover:text-white transition-colors font-normal text-base">Nosotros</a>
              <a href="#" class="text-white/60 hover:text-white transition-colors font-normal text-base">Proyectos</a>
              <a href="/equipo" class="text-white/60 hover:text-white transition-colors font-normal text-base">Equipo</a>
              <a href="#" class="text-white/60 hover:text-white transition-colors font-normal text-base">Sponsors</a>
            </div>
          </div>
          
          <div class="flex flex-col gap-6">
            <h3 class="text-white font-semibold text-lg">Contacto</h3>
            <div class="flex flex-col gap-4">
              <a href="mailto:contacto@coheteriabeauchef.cl" class="text-white/60 hover:text-white transition-colors font-normal text-base">contacto@coheteriabeauchef.cl</a>
              <p class="text-white/60 font-normal text-base">Beauchef 851, Santiago</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="w-full h-px bg-white/10"></div>
      
      <div class="w-full flex flex-col sm:flex-row justify-between items-center gap-4">
        <span class="text-white/40 font-normal text-sm text-center">© 2026 Cohetería Beauchef. Todos los derechos reservados.</span>
        <span class="text-white/40 font-normal text-sm text-center">Diseñado y desarrollado por el equipo de software.</span>
      </div>
    </footer>
  </main>
</Layout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
</style>
