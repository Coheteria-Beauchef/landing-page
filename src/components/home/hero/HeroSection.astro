---
import { headerNavigationLinks } from "../../../data/home";
import ActionButton from "../shared/ActionButton.astro";
import Brand from "../shared/Brand.astro";
import NavLinks from "../shared/NavLinks.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<section
  class="relative w-full bg-[#0A0A0A] overflow-hidden"
  style="height: calc(100svh + var(--home-announcement-height, 0px)); min-height: calc(720px + var(--home-announcement-height, 0px));"
  data-home-hero
>
  <img
    src={`${baseUrl}main_image.webp`}
    alt="Equipo de Cohetería Beauchef"
    width="2200"
    height="1650"
    loading="eager"
    decoding="sync"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover object-[center_18%] opacity-85"
  />

  <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A] via-[#1024b0e6] to-[#1025B9E6] opacity-45"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_10%,rgb(10_10_10_/_0.18)_55%,rgb(10_10_10_/_0.56)_100%)]"></div>

  <nav
    data-home-nav
    class="site-nav animate-nav-in fixed inset-x-0 z-30 transition-all duration-300 ease-out"
    style="top: var(--home-announcement-height, 0px);"
  >
    <div class="flex h-20 items-center justify-between px-6 md:px-10 lg:px-16">
      <Brand
        className="relative z-10"
        logoClass="w-11 h-11 object-contain shrink-0"
        textClass="home-brand-text text-white font-bold text-base sm:text-lg lg:text-xl tracking-[2px] transition-colors duration-300"
      />
      <NavLinks
        links={headerNavigationLinks}
        className="hidden md:flex items-center gap-6 lg:gap-10"
        linkClass="home-nav-link text-white font-semibold text-base transition-colors duration-300"
      />
      <button
        class="relative z-10 flex md:hidden flex-col justify-center items-center w-10 h-10 gap-[5px]"
        data-hamburger
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center" data-bar-1></span>
        <span class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300" data-bar-2></span>
        <span class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center" data-bar-3></span>
      </button>
    </div>

    <div
      class="mobile-menu md:hidden overflow-hidden"
      style="max-height: 0; transition: max-height 0.3s ease;"
      data-mobile-menu
    >
      <div class="flex flex-col px-6 pb-4">
        {headerNavigationLinks.map((link) => (
          <a href={link.href} class="py-3 text-white font-semibold text-base border-b border-white/10 last:border-0">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <div
    class="absolute inset-0 z-10 flex flex-col items-center justify-end gap-6 px-6 pb-14 text-center md:px-10 lg:px-16 lg:pb-20"
    style="padding-top: calc(6rem + var(--home-announcement-height, 0px));"
  >
    <h1 class="animate-hero-in [animation-delay:140ms] max-w-5xl text-white font-bold text-5xl sm:text-7xl lg:text-[84px] leading-none tracking-[-2px] lg:tracking-[-3px] [animation-fill-mode:both]">
      Cohetería Beauchef
    </h1>
    <p class="animate-hero-in [animation-delay:260ms] max-w-3xl text-[#FFFFFFEE] font-normal text-lg sm:text-xl lg:text-2xl leading-relaxed tracking-[-0.5px] [animation-fill-mode:both]">
      Desarrollamos e investigamos tecnología<br />
      para cohetería e ingeniería aeroespacial
    </p>
    <div class="animate-hero-in [animation-delay:380ms] mt-4 flex flex-col items-center gap-4 sm:flex-row [animation-fill-mode:both]">
      <ActionButton href="#proyectos" label="Ver Nuestros Proyectos" />
      <ActionButton href={`${baseUrl}equipo`} label="Únete al Equipo" variant="secondary" />
    </div>
  </div>
</section>

<style>
  .site-nav {
    background: transparent;
  }

  .site-nav .home-brand-text,
  .site-nav .home-nav-link {
    color: white;
  }

  .site-nav .home-nav-link:hover {
    color: rgb(226 232 240);
  }

  .site-nav.is-scrolled .home-nav-link:hover {
    color: rgb(191 219 254);
  }

  @keyframes nav-in {
    0% {
      opacity: 0;
      transform: translateY(-18px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-in {
    0% {
      opacity: 0;
      transform: translateY(28px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-nav-in {
    animation: nav-in 620ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .animate-hero-in {
    animation: hero-in 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-nav-in,
    .animate-hero-in {
      animation: none;
    }
  }
</style>

<script>
  import { initHeroSection } from "./initHeroSection";

  initHeroSection();
</script>
