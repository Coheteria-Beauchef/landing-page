---
import { homeStats } from "../../../data/home";
---

<section
  id="nosotros"
  data-about-section
  class="relative w-full overflow-hidden bg-white scroll-mt-24"
>
  <div class="relative z-10 mx-auto w-full max-w-[1400px] px-6 py-16 sm:px-8 sm:py-20 lg:px-16 lg:py-24">
      <div class="flex flex-col text-center items-center">
        <div class="about-title-wrap overflow-hidden">
          <h2 class="about-title text-[3.5rem] font-black leading-[0.92] tracking-[-0.06em] text-[#1C1C1E] sm:text-7xl lg:text-8xl">
            Impulsando la
            <span class="text-[#1025B9]">ingenier&iacute;a</span><br />
            aeroespacial
          </h2>
        </div>

        <div class="about-subtitle-wrap mt-8 overflow-hidden sm:mt-10">
          <p class="about-subtitle max-w-[560px] text-lg font-normal leading-[1.7] text-[#48484A] sm:text-xl">
            Estudiantes de la Facultad de Ciencias F&iacute;sicas y Matem&aacute;ticas de la
            Universidad de Chile. En 2025 dise&ntilde;amos, fabricamos y validamos el primer motor
            cohete 100% desarrollado por estudiantes.
          </p>
        </div>
      </div>

      <div class="lg:col-span-12 flex flex-col items-center text-center">
        <div class="about-stats-grid mt-16 grid grid-cols-2 gap-x-8 gap-y-10 sm:gap-x-12 sm:gap-y-14 lg:mt-20 lg:grid-cols-4 lg:gap-x-8 xl:gap-x-16">
          {homeStats.map((stat, i) => (
            <div class="about-stat-item" style={`--stat-index: ${i}`}>
              <div class="stat-value text-4xl font-black tracking-[-0.04em] text-[#1025B9] sm:text-5xl lg:text-6xl">
                {stat.value}
              </div>
              <div class="stat-label mt-2 text-sm font-medium uppercase tracking-[0.12em] text-[#8E8E93]">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
  </div>
</section>

<script>
  import { initAboutSection } from "./initAboutSection";

  initAboutSection();
</script>
