---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props as Props;
---

<div class="flex flex-col items-center gap-2 text-center">
  <span class="text-4xl font-bold text-[#2E34E0] sm:text-5xl lg:text-6xl">{value}</span>
  <span class="max-w-[14ch] text-sm leading-snug font-normal text-[#8E8E93] sm:text-[15px] lg:text-base">{label}</span>
</div>
