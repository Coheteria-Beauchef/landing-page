---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props as Props;
---

<div class="flex flex-col items-center gap-2">
  <span class="text-[#2E34E0] font-bold text-4xl lg:text-6xl">{value}</span>
  <span class="text-[#8E8E93] font-normal text-sm lg:text-base text-center">{label}</span>
</div>
