---
import { instagramPosts } from "../../data/home";
import { socialProfiles } from "../../data/home";
import InstagramCard from "./InstagramCard.astro";
import SocialIcon from "./SocialIcon.astro";
---

<section
  id="proyectos"
  class="w-full bg-white py-[100px] px-8 lg:px-[120px] flex flex-col items-center gap-12 scroll-mt-24"
  >
  <h2 class="text-[#1C1C1E] font-bold text-6xl leading-[1.15] tracking-[-2px] text-center fade-in-up">
      Nuestros Últimos Posts<br />en Instagram
    </h2>
  <div class="flex items-center gap-2 fade-in-up">
    <a
      href={socialProfiles.instagram}
      target="_blank"
      rel="noreferrer"
      class="flex items-center gap-2 group"
    >
      <SocialIcon platform="instagram" size={32} className="text-[#E1306C]" />
      <span class="text-[#2E34E0] font-semibold text-4xl relative inline-block">
      @coheteriabeauchef
      <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E34E0] group-hover:w-full transition-all duration-300"></span>
      </span>
    </a>
  </div>

  <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto fade-in-up" style="transition-delay: 150ms;">
    {
      instagramPosts.map((post) => (
        <InstagramCard
          excerpt={post.excerpt}
          likes={post.likes}
          comments={post.comments}
          imageSrc={post.imageSrc}
          imageAlt={post.imageAlt}
        />
      ))
    }
  </div>
</section>
