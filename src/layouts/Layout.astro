---
import "../styles/global.css";

// Tipos y Constantes para SEO (Search Engine Optimization)
// SEO permite mejorar la visibilidad de la página en motores de búsqueda y redes sociales 
type SeoLink = {
    href: string;
};

type StructuredData = Record<string, unknown> | Record<string, unknown>[];

interface Props {
    title?: string;
    description?: string;
    canonical?: string;
    keywords?: string[];
    ogImage?: string;
    ogType?: string;
    robots?: string;
    socialLinks?: SeoLink[];
    structuredData?: StructuredData;
}

const {
    title = "Coheteria Beauchef",
    description = "Landing Page estatica de Coheteria Beauchef construida con Astro.",
    canonical,
    keywords = [],
    ogImage,
    ogType = "website",
    robots = "index, follow",
    socialLinks = [],
    structuredData,
} = Astro.props;

const pageTitle = title;
const currentUrl = canonical
    ?? (Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined);
const normalizedOgImage = ogImage
    ? new URL(ogImage, Astro.site ?? Astro.url).toString()
    : undefined;
const keywordsContent = keywords.join(", ");
const serializedStructuredData = structuredData
    ? JSON.stringify(structuredData)
    : undefined;
---

<!doctype html>
<html lang="es">
    <head>
        <!-- Metadatos para SEO -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <meta name="robots" content={robots} />
        {keywordsContent && <meta name="keywords" content={keywordsContent} />}
        {currentUrl && <link rel="canonical" href={currentUrl} />}

        <meta property="og:locale" content="es_CL" />
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        {currentUrl && <meta property="og:url" content={currentUrl} />}
        <meta property="og:site_name" content="Cohetería Beauchef" />
        {
            normalizedOgImage && (
                <meta property="og:image" content={normalizedOgImage} />
            )
        }

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />
        {
            normalizedOgImage && (
                <meta name="twitter:image" content={normalizedOgImage} />
            )
        }

        {
            socialLinks.map((socialLink) => (
                <link rel="me" href={socialLink.href} />
            ))
        }

        <link
            rel="icon"
            type="image/png"
            href="/coheteriabeauchef_borderless_logo.png"
        />
        <link
            rel="apple-touch-icon"
            href="/coheteriabeauchef_borderless_logo.png"
        />
        <title>{pageTitle}</title>
        {
            serializedStructuredData && (
                <script
                    type="application/ld+json"
                    set:html={serializedStructuredData}
                />
            )
        }
        <slot name="head" />
    </head>
    <!-- Componente principal -->
    <!-- Contiene el contenido de la página; fondo, texto -->
    <body class="min-h-screen bg-neutral-950 text-white antialiased">
        <slot />
        <!-- Script que activa animaciones de fade-in al hacer scroll -->
        <script>
            function initFadeIn() {
                const observerOptions = {
                    root: null,
                    rootMargin: "0px",
                    threshold: 0.15,
                };

                const observer = new IntersectionObserver(
                    (entries, observer) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                observer.unobserve(entry.target);
                            }
                        });
                    },
                    observerOptions,
                );

                const fadeElements = document.querySelectorAll(".fade-in-up");
                fadeElements.forEach((el) => observer.observe(el));
            }

            document.addEventListener("DOMContentLoaded", initFadeIn);
        </script>
    </body>
</html>
